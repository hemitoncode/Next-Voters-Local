%% AI Politician Accountability System
flowchart LR
  %% Collection
  subgraph Collection[Data Collection]
    UL["User Location (Python)\n– gets lat/long"] --> ON["OpenNorth API Fetcher\n– fetches representatives by point"]
  end

  ON --> MQ["Task Queue\n– queue research jobs"]

  %% Manager / Agents
  subgraph Manager[Deep Research Agent - Manager Pattern]
    MQ --> MGR["Orchestrator\n– dispatches tasks to agents"]
    MGR --> A1["Agent: Political Activities\n– finds public political actions"]
    MGR --> A2["Agent: Controversies\n– searches for personal controversies"]
    MGR --> A3["Agent: Voting & Policy\n– collects voting records and stated positions"]
  end

  A1 --> SUP["Supervisor\n– collects HTML + metadata"]
  A2 --> SUP
  A3 --> SUP

  %% Post-processing & Storage
  SUP --> SUM["Summarizer LLM\n– summarizes collected HTML"]

  SUM --> ADT["Adult Summary\n– semi-formal summary for adults"]
  SUM --> KID["Kid Summary (fine-tuned)\n– slang/age-appropriate summary for kids"]

  ADT --> UIAdult["Adult UI\n– web/mobile interface"]
  KID --> UIKid["Kid UI\n– simplified, engaging interface"]

  classDef box stroke:#333,stroke-width:1px,fill:#f3f4f6;
  class Collection,Manager box;
